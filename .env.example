# SAP BAS Keepalive 环境变量配置

# ============ 多账号模式（推荐）============
# 每个账号一组，索引从 1 开始递增，BAS_NAME_x 可选
# 脚本会自动检测 BAS_URL_1 是否存在来决定多账号/单账号模式

# 账号1
BAS_URL_1=https://xxx.trial.applicationstudio.cloud.sap
BAS_EMAIL_1=user1@example.com
BAS_PASSWORD_1=your_password
BAS_WSID_1=ws-abc
# BAS_NAME_1=我的账号1

# 账号2
BAS_URL_2=https://yyy.trial.applicationstudio.cloud.sap
BAS_EMAIL_2=user2@example.com
BAS_PASSWORD_2=your_password
BAS_WSID_2=ws-def
# BAS_NAME_2=我的账号2

# ============ 单账号模式 ============
# 如果不设置 BAS_URL_1，则使用以下单个账号变量
# BAS_URL=
# BAS_EMAIL=
# BAS_PASSWORD=
# BAS_WSID=

# 可选：隐私弹窗点击后等待时间（毫秒），默认 800
# BAS_POST_PRIVACY_WAIT_MS=800

# 可选：查找"保持登录"复选框超时时间（毫秒），默认 1800
# BAS_REMEMBER_WAIT_MS=1800

# ============ 浏览器显示配置（直接连接模式，无需代理）============
# 是否显示浏览器界面（headless模式）
# true: 无头模式，不显示浏览器界面（适合服务器环境）
# false: 显示浏览器界面（适合调试和可视化操作）
# HEADLESS=true
