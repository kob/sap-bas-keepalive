# SAP BAS Keepalive 环境变量配置

# ============ 多账号模式（推荐）============
# 每个账号一组，索引从 1 开始递增，BAS_NAME_x 可选
# 脚本会自动检测 BAS_URL_1 是否存在来决定多账号/单账号模式

# 账号1
BAS_URL_1=https://xxx.trial.applicationstudio.cloud.sap
BAS_EMAIL_1=user1@example.com
BAS_PASSWORD_1=your_password
BAS_WSID_1=ws-abc
# BAS_NAME_1=我的账号1

# 账号2
BAS_URL_2=https://yyy.trial.applicationstudio.cloud.sap
BAS_EMAIL_2=user2@example.com
BAS_PASSWORD_2=your_password
BAS_WSID_2=ws-def
# BAS_NAME_2=我的账号2

# ============ 单账号模式 ============
# 如果不设置 BAS_URL_1，则使用以下单个账号变量
# BAS_URL=
# BAS_EMAIL=
# BAS_PASSWORD=
# BAS_WSID=

# 可选：隐私弹窗点击后等待时间（毫秒），默认 800
# BAS_POST_PRIVACY_WAIT_MS=800

# 可选：查找"保持登录"复选框超时时间（毫秒），默认 1800
# BAS_REMEMBER_WAIT_MS=1800

# ============ 代理配置（解决国内网络慢的问题）============
# 代理模式：direct（直接连接）、cf-worker（Cloudflare Worker）、custom-proxy（自定义代理）
# PROXY_MODE=direct

# 方案1：HTTP代理服务器
# PROXY_URL=http://proxy.example.com:8080
# PROXY_BYPASS=localhost,127.0.0.1,*.cloud.sap

# 方案2：Cloudflare Worker反代（推荐）
# PROXY_MODE=cf-worker
# CF_WORKER_URL=https://your-worker-name.your-subdomain.workers.dev

# 方案3：自定义代理（将目标域名作为子域名）
# PROXY_MODE=custom-proxy
# CUSTOM_PROXY_BASE=https://proxy.example.com
