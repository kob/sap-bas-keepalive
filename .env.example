# ============================================
# SAP BAS Keepalive 环境变量配置
# ============================================

# 单账号模式
BAS_URL=https://xxx.applicationstudio.cloud.sap
BAS_EMAIL=your.email@example.com
BAS_PASSWORD=yourpassword
BAS_WSID=your-workspace-id

# ============================================
# 多账号模式（推荐）- 优先级最高
# ============================================
# ACCOUNTS_JSON=$(cat << 'EOF'
# [
#   {
#     "name": "账号1",
#     "url": "https://xxx.applicationstudio.cloud.sap",
#     "email": "email1@example.com",
#     "password": "password1",
#     "wsid": "workspace-id-1"
#   },
#   {
#     "name": "账号2",
#     "url": "https://yyy.applicationstudio.cloud.sap",
#     "email": "email2@example.com",
#     "password": "password2",
#     "wsid": "workspace-id-2"
#   }
# ]
# EOF
# )

# ============================================
# 多账号模式（备选）- 逐行索引
# ============================================
# BAS_URL_1=https://xxx.applicationstudio.cloud.sap
# BAS_EMAIL_1=email1@example.com
# BAS_PASSWORD_1=password1
# BAS_WSID_1=workspace-id-1
# BAS_NAME_1=账号1
#
# BAS_URL_2=https://yyy.applicationstudio.cloud.sap
# BAS_EMAIL_2=email2@example.com
# BAS_PASSWORD_2=password2
# BAS_WSID_2=workspace-id-2
# BAS_NAME_2=账号2

# ============================================
# 执行配置
# ============================================
# 定时执行 Cron 表达式（默认每30分钟）
# CRON="*/30 * * * *"

# 时区（默认 Asia/Shanghai）
# TZ="Asia/Shanghai"

# 单次执行模式（设置为1禁用定时）
# NO_CRON=1

# 浏览器模式：true=无头模式，false=显示界面
# HEADLESS=true

# "保持登录"复选框检测超时（毫秒）
# BAS_REMEMBER_WAIT_MS=1800

# 隐私弹窗点击后等待（毫秒）
# BAS_POST_PRIVACY_WAIT_MS=800
